{
  "name": "codemod-recipe",
  "displayName": "Codemod Recipe",
  "description": "Browse, run, and review codemod_recipe transformations with an interactive diff and selective apply.",
  "version": "0.1.0",
  "publisher": "codemod-recipe",
  "repository": {
    "type": "git",
    "url": "https://github.com/c4rl2s0n/CodemodRecipe"
  },
  "license": "BSD-3-Clause",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codemodRecipe",
          "title": "Codemod Recipe",
          "icon": "media/recipe.svg"
        }
      ]
    },
    "views": {
      "codemodRecipe": [
        {
          "type": "webview",
          "id": "codemodRecipe.runner",
          "name": "Codemod Recipe",
          "icon": "media/recipe.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "codemodRecipe.refresh",
        "title": "Codemod Recipe: Refresh Recipes",
        "icon": "$(refresh)"
      },
      {
        "command": "codemodRecipe.runRecipe",
        "title": "Codemod Recipe: Run Recipe",
        "icon": "$(play)"
      },
      {
        "command": "codemodRecipe.runFromCursorContext",
        "title": "Codemod Recipe: Run From Cursor Context",
        "icon": "$(wand)"
      },
      {
        "command": "codemodRecipe.configureHost",
        "title": "Codemod Recipe: Set Host Entry Point"
      }
    ],
    "keybindings": [
      {
        "command": "codemodRecipe.runFromCursorContext",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codemodRecipe.refresh",
          "when": "view == codemodRecipe.runner",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "codemodRecipe.runFromCursorContext",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Codemod Recipe",
      "properties": {
        "codemodRecipe.hostEntrypoint": {
          "type": "string",
          "default": "",
          "description": "Path (relative to the workspace root) of the Dart host entry point that registers recipes via CodemodHost. Defaults to common locations when empty."
        },
        "codemodRecipe.dartPath": {
          "type": "string",
          "default": "dart",
          "description": "Path to the Dart executable used to run the host."
        },
        "codemodRecipe.recipesDirectory": {
          "type": "string",
          "default": ".codemod/recipes",
          "description": "Workspace-relative directory containing YAML recipe files."
        },
        "codemodRecipe.templatesRoot": {
          "type": "string",
          "default": ".codemod/templates",
          "description": "Workspace-relative root for templateFile and runScript paths in YAML recipes."
        },
        "codemodRecipe.emptyConstructorStyle": {
          "type": "string",
          "enum": ["named", "positional"],
          "default": "named",
          "description": "Constructor parameter style for empty constructors in generated code."
        },
        "codemodRecipe.performanceLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable performance timing logs for list/preview/apply host calls."
        },
        "codemodRecipe.autoPreviewDebounceMs": {
          "type": "number",
          "default": 400,
          "minimum": 100,
          "maximum": 2000,
          "description": "Debounce delay (milliseconds) for automatic preview updates."
        },
        "codemodRecipe.previewSnippetLines": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of lines shown per file in compact live preview cards."
        }
      }
    }
  },
  "scripts": {
    "build:webview": "vite build --config src/webview/vite.config.ts",
    "compile": "npm run build:webview && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "watch:webview": "vite build --config src/webview/vite.config.ts --watch",
    "test:webview": "vitest run --config src/webview/vitest.config.ts",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.14",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  }
}
